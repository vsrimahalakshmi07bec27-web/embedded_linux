#include <fcntl.h>
#include <unistd.h> 
#include <stdio.h>   
#include <sys/stat.h> 
int main() {
    int fd;
    char buf[50];
    fd = open("myfile.txt", O_CREAT | O_RDWR | O_TRUNC, 0644);
    write(fd, "welcome of file handling Emb.Linux", 35);
    lseek(fd, 0, SEEK_SET);
    read(fd, buf, 35);
    buf[35] = '\0'; // Null-terminate string for printf
    printf("\nFile contents: %s\n", buf);
    close(fd);
    if (chmod("myfile.txt", S_IRUSR | S_IRGRP | S_IROTH) == 0) {
        printf("Permissions changed to Read-Only.\n");
    }
    return 0;
}
